pipeline {
    agent any

    environment {
        FLUTTER_VERSION = "3.32.7"
        FLUTTER_HOME = "$WORKSPACE/flutter"
        PATH = "$FLUTTER_HOME/bin:$PATH"
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Checking out code from GitHub..."
                checkout([$class: 'GitSCM',
                    branches: [[name: 'flutter_cicd_shilpi']],
                    userRemoteConfigs: [[
                        url: 'https://github.com/Greencreon-LLP-2/GreenBiller-Windows-App-v1.git'
                    ]]
                ])
            }
        }

        stage('Set up Flutter') {
            steps {
                echo "Setting up Flutter SDK..."
                sh '''
                # Clone Flutter SDK if not already present
                if [ ! -d "$FLUTTER_HOME" ]; then
                    git clone https://github.com/flutter/flutter.git -b stable --depth 1 $FLUTTER_HOME
                fi

                flutter doctor
                flutter --version
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                echo "Installing Flutter dependencies..."
                sh 'flutter pub get'
            }
        }

        stage('Run Tests') {
            steps {
                echo "Running Flutter tests..."
                sh '''
                flutter test || echo "Some tests failed, but continuing..."
                '''
            }
        }

        stage('Build APK') {
            steps {
                echo "Building release APK..."
                sh 'flutter build apk --release'
            }
        }

        stage('Archive APK') {
            steps {
                echo "Archiving APK..."
                archiveArtifacts artifacts: 'build/app/outputs/flutter-apk/app-release.apk', fingerprint: true
            }
        }
    }

    post {
        success {
            echo "✅ Build Successful!"
        }
        unstable {
            echo "⚠️ Build completed with warnings or test failures."
        }
        failure {
            echo "❌ Build Failed!"
        }
    }
}
